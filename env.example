# Database
# DATABASE_URL: Transaction pooler URL (port 6543, pgbouncer=true)
DATABASE_URL="postgres://[user].[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL: Session URL (port 5432) for Prisma migrations
DIRECT_URL="postgres://[user].[project]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Google Sheets (if using)
GOOGLE_SERVICE_ACCOUNT=""
GOOGLE_SHEET_ID=""
GOOGLE_SHEET_FILENAME=""

# Paystack Configuration
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_your_public_key_here"
PAYSTACK_SECRET_KEY="sk_test_your_secret_key_here"
PAYSTACK_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password_here"
ADMIN_EMAIL="admin@tadorado.com" 

# Supabase Storage (for Epic 2)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"